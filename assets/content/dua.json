    "source": "سورة آل عمران: 8"
  },
  {
    "id": 110,
    "text": "رَبَّنَا هَبْ لَنَا مِنْ أَزْوَاجِنَا وَذُرِّيَّاتِنَا قُرَّةَ أَعْيُنٍ",
    "category": "أدعية قرآنية",
    "source": "سورة الفرقان: 74"
  },
  {
    "id": 111,
    "text": "اللهم إني أعوذ بك من الهم والحزن",
    "category": "أدعية نبوية",
    "source": "صحيح البخاري"
  },
  {
    "id": 112,
    "text": "اللهم إني أسألك العفو والعافية",
    "category": "أدعية نبوية",
    "source": "سنن ابن ماجه"
  },
  {
    "id": 113,
    "text": "يا مقلب القلوب ثبت قلبي على دينك",
