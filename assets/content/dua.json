[
  {
    "id": 1,
    "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ",
    "category": "أدعية قرآنية",
    "source": "سورة البقرة: 201"
  },
  {
    "id": 2,
    "text": "رَبِّ اشْرَحْ لِي صَدْرِي وَيَسِّرْ لِي أَمْرِي",
    "category": "أدعية قرآنية",
    "source": "سورة طه: 25-26"
  },
  {
    "id": 3,
    "text": "رَبِّ زِدْنِي عِلْمًا",
    "category": "أدعية قرآنية",
    "source": "سورة طه: 114"
  },
  {
    "id": 4,
    "text": "رَبَّنَا لَا تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا",
    "category": "أدعية قرآنية",
    "source": "سورة آل عمران: 8"
  },
  {
    "id": 5,
    "text": "رَبَّنَا هَبْ لَنَا مِنْ أَزْوَاجِنَا وَذُرِّيَّاتِنَا قُرَّةَ أَعْيُنٍ",
    "category": "أدعية قرآنية",
    "source": "سورة الفرقان: 74"
  },
  {
    "id": 6,
    "text": "اللهم إني أعوذ بك من الهم والحزن",
    "category": "أدعية نبوية",
    "source": "صحيح البخاري"
  },
  {
    "id": 7,
    "text": "اللهم إني أسألك العفو والعافية",
    "category": "أدعية نبوية",
    "source": "سنن ابن ماجه"
  },
  {
    "id": 8,
    "text": "يا مقلب القلوب ثبت قلبي على دينك",
    "category": "أدعية نبوية",
    "source": "سنن الترمذي"
  },
  {
    "id": 9,
    "text": "اللهم إني أعوذ بك من زوال نعمتك",
    "category": "أدعية نبوية",
    "source": "صحيح مسلم"
  },
  {
    "id": 10,
    "text": "اللهم ارزقني حسن الخاتمة",
    "category": "أدعية نبوية",
    "source": "مأثور"
  },
  {
    "id": 11,
    "text": "اللهم اغفر لي ولوالدي",
    "category": "أدعية عامة",
    "source": "سورة نوح: 28"
  },
  {
    "id": 12,
    "text": "اللهم ارزقني رزقًا طيبًا",
    "category": "أدعية عامة",
    "source": "سنن ابن ماجه"
  },
  {
    "id": 13,
    "text": "اللهم إني أسألك الجنة",
    "category": "أدعية عامة",
    "source": "سنن الترمذي"
  },
  {
    "id": 14,
    "text": "اللهم أصلح لي ديني ودنياي",
    "category": "أدعية عامة",
    "source": "صحيح مسلم"
  },
  {
    "id": 15,
    "text": "اللهم بارك لي في وقتي",
    "category": "أدعية عامة",
    "source": "مأثور"
  },
  {
    "id": 16,
    "text": "أستغفر الله العظيم وأتوب إليه",
    "category": "استغفار",
    "source": "مأثور"
  },
  {
    "id": 17,
    "text": "اللهم اغفر لي ذنبي كله",
    "category": "استغفار",
    "source": "صحيح مسلم"
  },
  {
    "id": 18,
    "text": "أستغفر الله الذي لا إله إلا هو",
    "category": "استغفار",
    "source": "سنن أبي داود"
  },
  {
    "id": 19,
    "text": "اللهم تب علي إنك أنت التواب الرحيم",
    "category": "استغفار",
    "source": "سورة البقرة: 128"
  },
  {
    "id": 20,
    "text": "أستغفر الله وأتوب إليه عدد خلقك",
    "category": "استغفار",
    "source": "صحيح مسلم"
  },
  {
    "id": 21,
    "text": "أصبحنا وأصبح الملك لله",
    "category": "أذكار الصباح",
    "source": "صحيح مسلم"
  },
  {
    "id": 22,
    "text": "اللهم بك أصبحنا وبك أمسينا",
    "category": "أذكار الصباح",
    "source": "سنن الترمذي"
  },
  {
    "id": 23,
    "text": "رضيت بالله ربًا وبالإسلام دينًا",
    "category": "أذكار الصباح",
    "source": "سنن أبي داود"
  },
  {
    "id": 24,
    "text": "حسبي الله لا إله إلا هو",
    "category": "أذكار الصباح",
    "source": "سورة التوبة: 129"
  },
  {
    "id": 25,
    "text": "اللهم إني أسألك خير هذا اليوم",
    "category": "أذكار الصباح",
    "source": "سنن أبي داود"
  },
  {
    "id": 26,
    "text": "أمسينا وأمسى الملك لله",
    "category": "أذكار المساء",
    "source": "صحيح مسلم"
  },
  {
    "id": 27,
    "text": "اللهم بك أمسينا وبك أصبحنا",
    "category": "أذكار المساء",
    "source": "سنن الترمذي"
  },
  {
    "id": 28,
    "text": "أعوذ بكلمات الله التامات من شر ما خلق",
    "category": "أذكار المساء",
    "source": "صحيح مسلم"
  },
  {
    "id": 29,
    "text": "رضيت بالله ربًا وبالإسلام دينًا",
    "category": "أذكار المساء",
    "source": "سنن أبي داود"
  },
  {
    "id": 30,
    "text": "اللهم احفظني من بين يدي ومن خلفي",
    "category": "أذكار المساء",
    "source": "سنن أبي داود"
  },
  {
    "id": 31,
    "text": "اللهم ارزقني رزقًا حلالًا طيبًا",
    "category": "رزق",
    "source": "مأثور"
  },
  {
    "id": 32,
    "text": "اللهم اكفني بحلالك عن حرامك",
    "category": "رزق",
    "source": "سنن الترمذي"
  },
  {
    "id": 33,
    "text": "اللهم ارزقني من حيث لا أحتسب",
    "category": "رزق",
    "source": "سورة الطلاق: 3"
  },
  {
    "id": 34,
    "text": "اللهم بارك لي في رزقي",
    "category": "رزق",
    "source": "مأثور"
  },
  {
    "id": 35,
    "text": "اللهم وسع علي رزقي",
    "category": "رزق",
    "source": "مسند أحمد"
  },
  {
    "id": 36,
