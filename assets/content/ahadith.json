[
  {
    "id": 1,
    "text": "التبسم في وجه أخيك صدقة",
    "narrator": "أبو هريرة",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 2,
    "text": "إنما الأعمال بالنيات، وإنما لكل امرئ ما نوى",
    "narrator": "عمر بن الخطاب",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 3,
    "text": "الدين النصيحة",
    "narrator": "تميم الداري",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 4,
    "text": "المسلم من سلم المسلمون من لسانه ويده",
    "narrator": "عبد الله بن عمرو",
    "source": "رواه البخاري"
  },
  {
    "id": 5,
    "text": "لا يؤمن أحدكم حتى يحب لأخيه ما يحب لنفسه",
    "narrator": "أنس بن مالك",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 6,
    "text": "من كان يؤمن بالله واليوم الآخر فليقل خيرًا أو ليصمت",
    "narrator": "أبو هريرة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 7,
    "text": "الطهور شطر الإيمان",
    "narrator": "أبو مالك الأشعري",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 8,
    "text": "يسروا ولا تعسروا، وبشروا ولا تنفروا",
    "narrator": "أنس بن مالك",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 9,
    "text": "خيركم من تعلم القرآن وعلمه",
    "narrator": "عثمان بن عفان",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 10,
    "text": "أحب الأعمال إلى الله أدومها وإن قل",
    "narrator": "عائشة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 11,
    "text": "من لا يَرحم لا يُرحم",
    "narrator": "أبو هريرة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 12,
    "text": "اتق الله حيثما كنت",
    "narrator": "أبو ذر الغفاري",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 13,
    "text": "اتبع السيئة الحسنة تمحها",
    "narrator": "أبو ذر الغفاري",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 14,
    "text": "وخير الناس أنفعهم للناس",
    "narrator": "جابر بن عبد الله",
    "source": "المعجم الأوسط",
    "favorites": false
  },
  {
    "id": 15,
    "text": "الكلمة الطيبة صدقة",
    "narrator": "أبو هريرة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 16,
    "text": "تبسمك في وجه أخيك لك صدقة",
    "narrator": "أبو ذر",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 17,
    "text": "ليس الشديد بالصرعة، إنما الشديد الذي يملك نفسه عند الغضب",
    "narrator": "أبو هريرة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 18,
    "text": "من سلك طريقًا يلتمس فيه علمًا سهل الله له به طريقًا إلى الجنة",
    "narrator": "أبو هريرة",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 19,
    "text": "الدنيا سجن المؤمن وجنة الكافر",
    "narrator": "أبو هريرة",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 20,
    "text": "من غشنا فليس منا",
    "narrator": "أبو هريرة",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 21,
    "text": "ارحموا من في الأرض يرحمكم من في السماء",
    "narrator": "عبد الله بن عمرو",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 22,
    "text": "إن الله جميل يحب الجمال",
    "narrator": "عبد الله بن مسعود",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 23,
    "text": "لا تغضب",
    "narrator": "أبو هريرة",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 24,
    "text": "من حسن إسلام المرء تركه ما لا يعنيه",
    "narrator": "أبو هريرة",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 25,
    "text": "اليد العليا خير من اليد السفلى",
    "narrator": "عبد الله بن عمر",
    "source": "رواه البخاري",
    "favorites": false
  },
  {
    "id": 26,
    "text": "من ستر مسلمًا ستره الله يوم القيامة",
    "narrator": "أبو هريرة",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 27,
    "text": "أقربكم مني مجلسًا يوم القيامة أحاسنكم أخلاقًا",
    "narrator": "جابر بن عبد الله",
    "source": "الترمذي",
    "favorites": false
  },
  {
    "id": 28,
    "text": "لا يدخل الجنة من كان في قلبه مثقال ذرة من كبر",
    "narrator": "عبد الله بن مسعود",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 29,
    "text": "الدال على الخير كفاعله",
    "narrator": "أبو مسعود الأنصاري",
    "source": "رواه مسلم",
    "favorites": false
  },
  {
    "id": 30,
    "text": "من أحب أن يُبسط له في رزقه ويُنسأ له في أثره فليصل رحمه",
    "narrator": "أنس بن مالك",
    "source": "رواه البخاري",
    "favorites": false
  }
]