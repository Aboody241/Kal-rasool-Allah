[
  {
    "id": 1,
    "text": "أصبحنا وأصبح الملك لله والحمد لله",
    "category": "أذكار الصباح",
    "source": "صحيح مسلم",
    "count": 1
  },
  {
    "id": 2,
    "text": "اللهم بك أصبحنا وبك أمسينا وبك نحيا وبك نموت وإليك النشور",
    "category": "أذكار الصباح",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 3,
    "text": "رضيت بالله ربًا وبالإسلام دينًا وبمحمد ﷺ نبيًا ورسولًا",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 3
  },
  {
    "id": 4,
    "text": "حسبي الله لا إله إلا هو عليه توكلت وهو رب العرش العظيم",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 7
  },
  {
    "id": 5,
    "text": "اللهم إني أسألك خير هذا اليوم",
    "category": "أذكار الصباح",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 6,
    "text": "أمسينا وأمسى الملك لله والحمد لله",
    "category": "أذكار المساء",
    "source": "صحيح مسلم",
    "count": 1
  },
  {
    "id": 7,
    "text": "اللهم بك أمسينا وبك أصبحنا وبك نحيا وبك نموت وإليك المصير",
    "category": "أذكار المساء",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 8,
    "text": "أعوذ بكلمات الله التامات من شر ما خلق",
    "category": "أذكار المساء",
    "source": "صحيح مسلم",
    "count": 3
  },
  {
    "id": 9,
    "text": "اللهم ما أمسى بي من نعمة فمنك وحدك",
    "category": "أذكار المساء",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 10,
    "text": "اللهم إني أسألك خير هذه الليلة",
    "category": "أذكار المساء",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 11,
    "text": "أستغفر الله",
    "category": "أذكار بعد الصلاة",
    "source": "صحيح مسلم",
    "count": 3
  },
  {
    "id": 12,
    "text": "اللهم أنت السلام ومنك السلام تباركت يا ذا الجلال والإكرام",
    "category": "أذكار بعد الصلاة",
    "source": "صحيح مسلم",
    "count": 1
  },
  {
    "id": 13,
    "text": "سبحان الله",
    "category": "أذكار بعد الصلاة",
    "source": "صحيح مسلم",
    "count": 33
  },
  {
    "id": 14,
    "text": "الحمد لله",
    "category": "أذكار بعد الصلاة",
    "source": "صحيح مسلم",
    "count": 33
  },
  {
    "id": 15,
    "text": "الله أكبر",
    "category": "أذكار بعد الصلاة",
    "source": "صحيح مسلم",
    "count": 33
  },
  {
    "id": 16,
    "text": "باسمك اللهم أموت وأحيا",
    "category": "أذكار النوم",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 17,
    "text": "اللهم قني عذابك يوم تبعث عبادك",
    "category": "أذكار النوم",
    "source": "أبو داود",
    "count": 3
  },
  {
    "id": 18,
    "text": "باسمك ربي وضعت جنبي وبك أرفعه",
    "category": "أذكار النوم",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 19,
    "text": "اللهم باسمك أحيا وأموت",
    "category": "أذكار النوم",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 20,
    "text": "رَبِّ زِدْنِي عِلْمًا",
    "category": "أدعية قرآنية",
    "source": "طه 114",
    "count": 1
  },
  {
    "id": 21,
    "text": "رَبِّ اشْرَحْ لِي صَدْرِي",
    "category": "أدعية قرآنية",
    "source": "طه 25",
    "count": 1
  },
  {
    "id": 22,
    "text": "رَبَّنَا آتِنَا فِي الدُّنْيَا حَسَنَةً وَفِي الْآخِرَةِ حَسَنَةً وَقِنَا عَذَابَ النَّارِ",
    "category": "أدعية قرآنية",
    "source": "البقرة 201",
    "count": 1
  },
  {
    "id": 23,
    "text": "رَبَّنَا لَا تُزِغْ قُلُوبَنَا بَعْدَ إِذْ هَدَيْتَنَا",
    "category": "أدعية قرآنية",
    "source": "آل عمران 8",
    "count": 1
  },
  {
    "id": 24,
    "text": "أستغفر الله العظيم وأتوب إليه",
    "category": "استغفار",
    "source": "مأثور",
    "count": 100
  },
  {
    "id": 25,
    "text": "اللهم اغفر لي وتب علي إنك أنت التواب الرحيم",
    "category": "استغفار",
    "source": "الترمذي",
    "count": 100
  },
  {
    "id": 26,
    "text": "سيد الاستغفار: اللهم أنت ربي لا إله إلا أنت خلقتني وأنا عبدك",
    "category": "استغفار",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 27,
    "text": "اللهم ارزقني رزقًا طيبًا مباركًا",
    "category": "رزق",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 28,
    "text": "اللهم اكفني بحلالك عن حرامك وأغنني بفضلك عمن سواك",
    "category": "رزق",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 29,
    "text": "اللهم بارك لي في رزقي",
    "category": "رزق",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 30,
    "text": "اللهم إني أسألك الجنة وأعوذ بك من النار",
    "category": "أدعية عامة",
    "source": "أبو داود",
    "count": 3
  },
  {
    "id": 31,
    "text": "اللهم اغفر لي ولوالدي",
    "category": "أدعية عامة",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 32,
    "text": "اللهم أصلح لي ديني ودنياي وآخرتي",
    "category": "أدعية عامة",
    "source": "صحيح مسلم",
    "count": 1
  },
  {
    "id": 33,
    "text": "اللهم ارزقني علمًا نافعًا وعملًا متقبلًا",
    "category": "أدعية عامة",
    "source": "ابن ماجه",
    "count": 1
  },
  {
    "id": 34,
    "text": "اللهم إني أصبحت أشهدك وأشهد حملة عرشك وملائكتك وجميع خلقك أنك أنت الله لا إله إلا أنت وحدك لا شريك لك وأن محمدًا عبدك ورسولك",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 4
  },
  {
    "id": 35,
    "text": "اللهم عافني في بدني، اللهم عافني في سمعي، اللهم عافني في بصري",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 3
  },
  {
    "id": 36,
    "text": "اللهم إني أعوذ بك من الكفر والفقر وأعوذ بك من عذاب القبر",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 3
  },
  {
    "id": 37,
    "text": "يا حي يا قيوم برحمتك أستغيث أصلح لي شأني كله",
    "category": "أذكار الصباح",
    "source": "النسائي",
    "count": 1
  },
  {
    "id": 38,
    "text": "اللهم فاطر السماوات والأرض عالم الغيب والشهادة رب كل شيء ومليكه",
    "category": "أذكار الصباح",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 39,
    "text": "اللهم إني أسألك العفو والعافية في الدنيا والآخرة",
    "category": "أذكار الصباح",
    "source": "ابن ماجه",
    "count": 1
  },
  {
    "id": 40,
    "text": "بسم الله الذي لا يضر مع اسمه شيء في الأرض ولا في السماء وهو السميع العليم",
    "category": "أذكار الصباح",
    "source": "الترمذي",
    "count": 3
  },
  {
    "id": 41,
    "text": "اللهم إني أعوذ بك من الهم والحزن والعجز والكسل",
    "category": "أدعية عامة",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 42,
    "text": "اللهم مصرف القلوب صرف قلوبنا على طاعتك",
    "category": "أدعية عامة",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 43,
    "text": "اللهم إني ظلمت نفسي ظلمًا كثيرًا فاغفر لي",
    "category": "استغفار",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 44,
    "text": "رب اغفر لي وتب علي إنك أنت التواب الرحيم",
    "category": "استغفار",
    "source": "الترمذي",
    "count": 100
  },
  {
    "id": 45,
    "text": "اللهم اغفر لي خطيئتي وجهلي وإسرافي في أمري",
    "category": "استغفار",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 46,
    "text": "اللهم إني أسألك الهدى والتقى والعفاف والغنى",
    "category": "أدعية عامة",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 47,
    "text": "اللهم أعني على ذكرك وشكرك وحسن عبادتك",
    "category": "أذكار بعد الصلاة",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 48,
    "text": "لا إله إلا الله وحده لا شريك له له الملك وله الحمد وهو على كل شيء قدير",
    "category": "أذكار بعد الصلاة",
    "source": "البخاري",
    "count": 10
  },
  {
    "id": 49,
    "text": "اللهم إني أعوذ بك من البخل والجبن",
    "category": "أدعية عامة",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 50,
    "text": "اللهم إني أعوذ بك من فتنة المحيا والممات",
    "category": "أدعية عامة",
    "source": "البخاري",
    "count": 1
  },
  {
    "id": 51,
    "text": "اللهم ثبت قلبي على دينك",
    "category": "أدعية عامة",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 52,
    "text": "ربنا ظلمنا أنفسنا وإن لم تغفر لنا وترحمنا لنكونن من الخاسرين",
    "category": "أدعية قرآنية",
    "source": "الأعراف 23",
    "count": 1
  },
  {
    "id": 53,
    "text": "رب هب لي من لدنك ذرية طيبة إنك سميع الدعاء",
    "category": "أدعية قرآنية",
    "source": "آل عمران 38",
    "count": 1
  },
  {
    "id": 54,
    "text": "رب أوزعني أن أشكر نعمتك التي أنعمت علي",
    "category": "أدعية قرآنية",
    "source": "النمل 19",
    "count": 1
  },
  {
    "id": 55,
    "text": "لا إله إلا أنت سبحانك إني كنت من الظالمين",
    "category": "أدعية قرآنية",
    "source": "الأنبياء 87",
    "count": 1
  },
  {
    "id": 56,
    "text": "رب ارحمهما كما ربياني صغيرًا",
    "category": "أدعية قرآنية",
    "source": "الإسراء 24",
    "count": 1
  },
  {
    "id": 57,
    "text": "اللهم ارزقني حبك وحب من يحبك",
    "category": "أدعية عامة",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 58,
    "text": "اللهم اجعل القرآن ربيع قلبي ونور صدري",
    "category": "أدعية عامة",
    "source": "أحمد",
    "count": 1
  },
  {
    "id": 59,
    "text": "اللهم إني أسألك حسن الخاتمة",
    "category": "أدعية عامة",
    "source": "مأثور",
    "count": 1
  },
  {
    "id": 60,
    "text": "اللهم اجعلني من التوابين واجعلني من المتطهرين",
    "category": "أذكار الوضوء",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 61,
    "text": "أشهد أن لا إله إلا الله وحده لا شريك له وأشهد أن محمدًا عبده ورسوله",
    "category": "أذكار الوضوء",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 62,
    "text": "اللهم افتح لي أبواب رحمتك",
    "category": "أذكار المسجد",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 63,
    "text": "اللهم إني أسألك من فضلك",
    "category": "أذكار المسجد",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 64,
    "text": "بسم الله توكلت على الله ولا حول ولا قوة إلا بالله",
    "category": "أذكار الخروج من المنزل",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 65,
    "text": "اللهم إني أعوذ بك أن أضل أو أُضل",
    "category": "أذكار الخروج من المنزل",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 66,
    "text": "بسم الله ولجنا وبسم الله خرجنا وعلى ربنا توكلنا",
    "category": "أذكار دخول المنزل",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 67,
    "text": "اللهم بارك لنا فيما رزقتنا وقنا عذاب النار",
    "category": "أذكار الطعام",
    "source": "الترمذي",
    "count": 1
  },
  {
    "id": 68,
    "text": "الحمد لله الذي أطعمنا وسقانا وجعلنا مسلمين",
    "category": "أذكار الطعام",
    "source": "أبو داود",
    "count": 1
  },
  {
    "id": 69,
    "text": "اللهم هون علينا سفرنا هذا واطو عنا بعده",
    "category": "أذكار السفر",
    "source": "مسلم",
    "count": 1
  },
  {
    "id": 70,
    "text": "آيبون تائبون عابدون لربنا حامدون",
    "category": "أذكار السفر",
    "source": "البخاري",
    "count": 1
  }
]